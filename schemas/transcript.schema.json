{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Transcript",
  "description": "Multi-session AI conversation transcript",
  "type": "object",
  "required": ["sessions"],
  "properties": {
    "sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["session_id", "turns"],
        "properties": {
          "session_id": {"type": "string"},
          "timestamp": {"type": "string", "format": "date-time"},
          "metadata": {"type": "object"},
          "turns": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["role", "content"],
              "properties": {
                "role": {"type": "string", "enum": ["user", "assistant", "system"]},
                "content": {"type": "string"},
                "turn_id": {"type": "string"},
                "timestamp": {"type": "string", "format": "date-time"}
              }
            }
          }
        }
      }
    }
  }
}
